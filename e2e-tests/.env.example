# Copy to `.env` and fill in the keys for the providers you want to probe.
# A provider with an empty/unset key is skipped automatically — set only what you have.
#
#   cp .env.example .env

# --- Distinct-dialect providers ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=

# --- OpenAI-wire family ---
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
REQUESTY_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
CEREBRAS_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=

# --- Local backends (only if you uncomment them in llmleaf.e2e.toml) ---
# OLLAMA_API_KEY=
# LMSTUDIO_API_KEY=

# --- Stack knobs (optional) ---
# RUST_LOG=info
# LLMLEAF_HOST_PORT=8080

# Voxtral TTS voice ids are account-scoped UUIDs (see your key's GET /audio/voices).
# Required for the mistral audio probe; defaults to a known-good id if unset.
# LLMLEAF_MISTRAL_VOICE=c69964a6-ab8b-4f8a-9465-ec0925096ec8
